# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Simulation outputs (do not commit; can be regenerated) ---
outputs/
output/
*.h5
*.hdf5
*.npz
results_arrays.npz
filtered/

# Per-tilt directories produced by the pipeline (both naming conventions
# the runner has emitted historically):
tilt_*mrad/
tilt_*mrad_*/

# Large crystal exports are regenerated by sample_generators on demand;
# small reference .cif/.xyz files inside the repo tree are still trackable
# if explicitly `git add`-ed.
**/outputs/*.cif
**/outputs/*.xyz

# Prismatique / Prismatic per-run parameter dumps
simulation_parameters.json
hrtem_sim_params.json

# Generated logs and figures
*.log
reconstruction_log.txt
*.png
!docs/**/*.png        # keep figures that are explicitly placed under docs/
